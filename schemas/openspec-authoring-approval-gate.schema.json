{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a5345534/goal-spec/schemas/openspec-authoring-approval-gate.schema.json",
  "title": "OpenSpec Authoring Approval Gate",
  "description": "Deterministic approval decision record. Must reference current report digest. Never uses implementation-execution language.",
  "type": "object",
  "required": ["schemaVersion", "changeName", "gate", "decision", "sourceReport", "inputDigests", "approvedBy", "approvalRationale", "decidedAt", "readyForSpecKernel"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "changeName": { "type": "string", "minLength": 1 },
    "gate": { "const": "openspec_authoring_approval" },
    "decision": { "enum": ["continue_discussion", "abandon_proposal", "accept_no_build_recommendation", "approve_smaller_scope_openspec_authoring", "approve_openspec_authoring"] },
    "allowedDecisions": {
      "type": "array",
      "items": { "enum": ["continue_discussion", "abandon_proposal", "accept_no_build_recommendation", "approve_smaller_scope_openspec_authoring", "approve_openspec_authoring"] }
    },
    "sourceReport": { "type": "string" },
    "inputDigests": { "type": "object", "additionalProperties": { "type": "string" } },
    "approvedBy": {
      "type": "object",
      "required": ["type", "id"],
      "additionalProperties": false,
      "properties": {
        "type": { "enum": ["human", "role", "orchestrator", "policy"] },
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "source": { "type": "string" },
        "sourceRef": { "type": "string" }
      }
    },
    "approvalRationale": { "type": "string" },
    "approvedScope": { "type": "string" },
    "readyForSpecKernel": { "type": "boolean" },
    "decidedAt": { "type": "string" },
    "choiceActionRequest": {
      "type": "object",
      "description": "Optional ChoiceActionRequest representation of this gate's decisions for harness-neutral presentation.",
      "required": ["requestId", "title", "choices", "fallbackPrompt"],
      "additionalProperties": false,
      "properties": {
        "requestId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "choices": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "label", "canonicalValue", "aliases"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "canonicalValue": { "type": "string" },
              "aliases": { "type": "array", "items": { "type": "string" } },
              "description": { "type": "string" },
              "disabled": { "type": "boolean" },
              "disabledReason": { "type": "string" }
            }
          }
        },
        "fallbackPrompt": { "type": "string" },
        "defaultChoiceId": { "type": "string" },
        "allowTextAliases": { "type": "boolean" },
        "metadata": { "type": "object" }
      }
    },
    "choiceActionSelectionResult": {
      "type": "object",
      "description": "Optional ChoiceActionSelectionResult recording how the user's selection was normalized.",
      "required": ["requestId", "choiceId", "canonicalValue", "inputMode", "renderMode"],
      "additionalProperties": false,
      "properties": {
        "requestId": { "type": "string" },
        "choiceId": { "type": "string" },
        "canonicalValue": { "type": "string" },
        "inputMode": { "enum": ["interactive", "text_alias", "canonical_text", "defaulted"] },
        "renderMode": { "enum": ["interactive", "text_fallback", "unsupported"] },
        "selectedAt": { "type": "string" }
      }
    }
  }
}
