{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a5345534/goal-spec/schemas/logic-closure-gate.schema.json",
  "title": "Logic Closure Gate",
  "description": "Generated by deterministic script. Status closed or not_closed.",
  "type": "object",
  "required": ["schemaVersion", "changeName", "gate", "status", "closed", "sourceAssessment", "inputDigests", "nextStep"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "changeName": { "type": "string", "minLength": 1 },
    "gate": { "const": "logic_closure" },
    "status": { "enum": ["closed", "not_closed"] },
    "closed": { "type": "boolean" },
    "sourceAssessment": { "type": "string" },
    "inputDigests": { "type": "object", "additionalProperties": { "type": "string" } },
    "blockingFields": { "type": "array", "items": { "type": "string" } },
    "nextStep": { "enum": ["logic_gap_completion", "change_value_assessment_report"] },
    "allowedNextSteps": { "type": "array", "items": { "enum": ["logic_gap_completion", "change_value_assessment_report"] } },
    "reason": { "type": "string" }
  }
}
