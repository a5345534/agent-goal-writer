{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a5345534/goal-spec/schemas/proposal-intake.schema.json",
  "title": "Proposal Intake",
  "description": "Raw proposal capture — no value judgment or OpenSpec source content.",
  "type": "object",
  "required": ["schemaVersion", "changeName", "rawProposal"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "changeName": { "type": "string", "minLength": 1 },
    "rawProposal": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "id": { "type": "string" }
      }
    },
    "receivedAt": { "type": "string" },
    "knownContext": { "type": "array", "items": { "type": "string" } },
    "initialUnknowns": { "type": "array", "items": { "type": "string" } }
  }
}
