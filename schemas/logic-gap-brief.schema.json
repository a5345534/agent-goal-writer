{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/a5345534/goal-spec/schemas/logic-gap-brief.schema.json",
  "title": "Logic Gap Brief",
  "description": "Concise gap questions produced by judge when logic is not closed.",
  "type": "object",
  "required": ["schemaVersion", "changeName", "role", "modelClass", "gaps", "questionsForDecisionMaker"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "changeName": { "type": "string", "minLength": 1 },
    "role": { "const": "judge" },
    "modelClass": { "const": "value-judge" },
    "sourceGate": { "type": "string" },
    "inputDigests": { "type": "object", "additionalProperties": { "type": "string" } },
    "summaryForDecisionMaker": { "type": "string" },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "brief", "whyItMatters"],
        "additionalProperties": false,
        "properties": {
          "field": { "type": "string" },
          "brief": { "type": "string" },
          "whyItMatters": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "questionsForDecisionMaker": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "blocksField", "question", "options"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "blocksField": { "type": "string" },
          "question": { "type": "string" },
          "options": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      },
      "minItems": 1
    },
    "maxQuestionsThisRound": { "type": "integer" }
  }
}
