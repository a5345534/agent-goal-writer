test_openspec_propose_scaffolds_files() {
    local tmp
    tmp=$(mktemp -d)
    local out rc
    set +e
    out=$("$OPENSPEC" --json propose propose-test --capability proposed-cap --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "propose exit" || ok=1
    local base="$tmp/openspec/changes/propose-test"
    [[ -f "$base/proposal.md" ]] || { printf "\n    ${RED}missing proposal.md${NC}\n"; ok=1; }
    [[ -f "$base/design.md" ]] || { printf "\n    ${RED}missing design.md${NC}\n"; ok=1; }
    [[ -f "$base/tasks.md" ]] || { printf "\n    ${RED}missing tasks.md${NC}\n"; ok=1; }
    [[ -f "$base/specs/proposed-cap/spec.md" ]] || { printf "\n    ${RED}missing spec.md${NC}\n"; ok=1; }
    [[ -f "$base/source-manifest.json" ]] || { printf "\n    ${RED}missing source-manifest.json${NC}\n"; ok=1; }
    [[ -f "$base/.openspec.yaml" ]] || { printf "\n    ${RED}missing .openspec.yaml${NC}\n"; ok=1; }
    local valid_out valid_rc
    set +e
    valid_out=$("$OPENSPEC" --json validate-source-manifest propose-test --project-root "$tmp" 2>&1)
    valid_rc=$?
    set -e
    assert_exit 0 "$valid_rc" "validate manifest after propose exit" || ok=1
    rm -rf "$tmp"
    return $ok
}

