# =====================================================================
# Section 4: DETERMINISTIC COMMAND AUDIT
# =====================================================================

test_deterministic_check_output() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "det-check" --capability "test" --goal "Test." > /dev/null 2>&1
    filled_gate_pass "det-check" "test" > "$tmp/.goal-spec/value-gate.json"
    local out1 out2 rc1 rc2
    set +e
    out1=$("$WORKFLOW" check --project-root "$tmp" 2>&1)
    rc1=$?
    out2=$("$WORKFLOW" check --project-root "$tmp" 2>&1)
    rc2=$?
    set -e
    local ok=0
    assert_exit 0 "$rc1" "first check exit" || ok=1
    assert_exit 0 "$rc2" "second check exit" || ok=1
    [[ "$rc1" -eq "$rc2" ]] || { printf "\n    ${RED}exit codes not stable: %d vs %d${NC}\n" "$rc1" "$rc2"; ok=1; }
    local status1 status2
    status1=$(echo "$out1" | python3 -c "import json,sys; print(json.load(sys.stdin).get('status',''))")
    status2=$(echo "$out2" | python3 -c "import json,sys; print(json.load(sys.stdin).get('status',''))")
    [[ "$status1" == "$status2" ]] || { printf "\n    ${RED}status not stable: %s vs %s${NC}\n" "$status1" "$status2"; ok=1; }
    echo "$out1" | python3 -c "import json,sys; json.load(sys.stdin)" > /dev/null 2>&1 \
        || { printf "\n    ${RED}output 1 is not valid JSON${NC}\n"; ok=1; }
    echo "$out2" | python3 -c "import json,sys; json.load(sys.stdin)" > /dev/null 2>&1 \
        || { printf "\n    ${RED}output 2 is not valid JSON${NC}\n"; ok=1; }
    local sv1 sv2
    sv1=$(echo "$out1" | python3 -c "import json,sys; print(json.load(sys.stdin).get('schemaVersion',''))")
    sv2=$(echo "$out2" | python3 -c "import json,sys; print(json.load(sys.stdin).get('schemaVersion',''))")
    [[ "$sv1" == "1.0" ]] || { printf "\n    ${RED}schemaVersion not 1.0 in output 1${NC}\n"; ok=1; }
    [[ "$sv2" == "1.0" ]] || { printf "\n    ${RED}schemaVersion not 1.0 in output 2${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_deterministic_gate_output() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "det-gate" --capability "test" --goal "Test." > /dev/null 2>&1
    filled_gate_pass "det-gate" "test" > "$tmp/.goal-spec/value-gate.json"
    local out1 out2 rc1 rc2
    set +e
    out1=$("$WORKFLOW" gate --pre-spec --project-root "$tmp" 2>&1)
    rc1=$?
    out2=$("$WORKFLOW" gate --pre-spec --project-root "$tmp" 2>&1)
    rc2=$?
    set -e
    local ok=0
    assert_exit 0 "$rc1" "first gate exit" || ok=1
    assert_exit 0 "$rc2" "second gate exit" || ok=1
    [[ "$rc1" -eq "$rc2" ]] || { printf "\n    ${RED}gate exit codes not stable${NC}\n"; ok=1; }
    [[ -f "$tmp/.goal-spec/pre-spec-gate.json" ]] || { printf "\n    ${RED}missing pre-spec-gate.json after gate${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_deterministic_write_spec_output() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "det-write" --capability "det-cap" --goal "Test." > /dev/null 2>&1
    filled_gate_pass "det-write" "det-cap" > "$tmp/.goal-spec/value-gate.json"
    local out1 rc1
    set +e
    out1=$("$WORKFLOW" write-spec --project-root "$tmp" 2>&1)
    rc1=$?
    set -e
    local ok=0
    assert_exit 0 "$rc1" "first write-spec exit" || ok=1
    echo "$out1" | python3 -c "import json,sys; json.load(sys.stdin)" > /dev/null 2>&1 \
        || { printf "\n    ${RED}write-spec output not valid JSON${NC}\n"; ok=1; }
    assert_json_field "$out1" "result" "written" "write result" || ok=1
    assert_json_field "$out1" "command" "write-spec" "command" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_all_commands_emit_valid_json() {
    local tmp
    tmp=$(mktemp -d)
    local ok=0
    local commands=(
        "check --project-root $tmp"
        "gate --pre-spec --project-root $tmp"
        "write-spec --project-root $tmp"
        "phase not-exists --active intake --status active --project-root $tmp"
    )
    for cmd in "${commands[@]}"; do
        local out rc
        set +e
        out=$(eval "$WORKFLOW $cmd" 2>&1)
        rc=$?
        set -e
        if ! echo "$out" | python3 -c "import json,sys; json.load(sys.stdin)" > /dev/null 2>&1; then
            printf "\n    ${RED}command '%s' did not emit valid JSON${NC}\n" "$cmd"
            ok=1
            break
        fi
    done
    rm -rf "$tmp"
    return $ok
}

# =====================================================================
# Section 5: DIGEST CANONICALIZATION
# =====================================================================

test_sha256_determinism() {
    local tmp
    tmp=$(mktemp -d)
    echo "Hello, World!" > "$tmp/test.txt"
    local hash1 hash2
    hash1=$(python3 -c "import hashlib; print(hashlib.sha256(open('$tmp/test.txt','rb').read()).hexdigest())")
    hash2=$(python3 -c "import hashlib; print(hashlib.sha256(open('$tmp/test.txt','rb').read()).hexdigest())")
    local ok=0
    [[ "$hash1" == "$hash2" ]] || { printf "\n    ${RED}sha256 not deterministic${NC}\n"; ok=1; }
    [[ "$hash1" =~ ^[a-f0-9]{64}$ ]] || { printf "\n    ${RED}invalid sha256 format: $hash1${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_manifest_digest_matches_content() {
    local tmp
    tmp=$(mktemp -d)
    local base="$tmp/openspec/changes/digest-test"
    mkdir -p "$base"
    echo "# Proposal content v1" > "$base/proposal.md"
    local hash_v1
    hash_v1=$(python3 -c "import hashlib; print(hashlib.sha256(open('$base/proposal.md','rb').read()).hexdigest())")

    local out rc
    set +e
    out=$("$OPENSPEC" --json build-source-manifest digest-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "build manifest exit" || ok=1

    local manifest_hash
    manifest_hash=$(python3 -c "
import json
manifest = json.load(open('$base/source-manifest.json'))
src = manifest['sources'][0]
assert src['path'] == 'proposal.md'
print(src['sha256'])
")
    [[ "$manifest_hash" == "$hash_v1" ]] || { printf "\n    ${RED}manifest digest doesn't match file${NC}\n"; ok=1; }

    set +e
    out=$("$OPENSPEC" --json validate-source-manifest digest-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "validate manifest after build exit" || ok=1

    rm -rf "$tmp"
    return $ok
}

test_manifest_detects_stale_digests() {
    local tmp
    tmp=$(mktemp -d)
    local base="$tmp/openspec/changes/stale-test"
    mkdir -p "$base"
    echo "# Original content" > "$base/proposal.md"
    local orig_hash
    orig_hash=$(python3 -c "import hashlib; print(hashlib.sha256(open('$base/proposal.md','rb').read()).hexdigest())")

    python3 -c "
import json
manifest = {
    'schemaVersion': '1.0',
    'changeName': 'stale-test',
    'generatedAt': '2024-01-01T00:00:00Z',
    'sources': [{'path': 'proposal.md', 'kind': 'proposal', 'sha256': '$orig_hash'}],
}
json.dump(manifest, open('$base/source-manifest.json', 'w'))
"
    local out rc ok=0
    set +e
    out=$("$OPENSPEC" --json validate-source-manifest stale-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "initial validate exit" || ok=1

    echo "# Modified content" > "$base/proposal.md"

    set +e
    out=$("$OPENSPEC" --json validate-source-manifest stale-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 1 "$rc" "stale digest detect exit" || ok=1
    echo "$out" | python3 -c "
import json,sys
d = json.load(sys.stdin)
stale = d.get('stale', [])
assert len(stale) > 0, f'stale should be non-empty: {d}'
" > /dev/null 2>&1 || { printf "\n    ${RED}stale digest not detected${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

