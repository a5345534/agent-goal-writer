#!/usr/bin/env bash
# Comprehensive test suite for goal-spec covering:
#   - Canonical artifact validators (value-gate schema, source-manifest schema)
#   - Logic closure paths (placeholder detection, field_status, boundary validation)
#   - Approval decisions (acknowledgement edge cases, compound gate scenarios)
#   - Write-spec gating (extended edge cases)
#   - Role-run audit (profile schema validation, separation rules)
#   - Deterministic command audit (exit code stability, JSON structure stability)
#   - Boundary validators (malformed JSON, missing fields, invalid values)
#   - Digest canonicalization (sha256 stability, manifest digest matching)
#   - Package validation (propose, build-manifest, validate-manifest, archive-preflight)
#
# Deterministic validation: every subcommand emits stable JSON exit codes.
# This runner verifies both exit codes and key fields in the output payload.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
WORKFLOW="$SCRIPT_DIR/goal-spec-workflow"
OPENSPEC="$SCRIPT_DIR/goal-spec-openspec.py"

PASS=0
FAIL=0
SKIP=0
TOTAL=0

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# --- helpers ---

run_test() {
    local name="$1"
    shift
    TOTAL=$((TOTAL + 1))
    printf "  %-68s " "$name"
    if "$@"; then
        PASS=$((PASS + 1))
        printf "${GREEN}PASS${NC}\n"
    else
        FAIL=$((FAIL + 1))
        printf "${RED}FAIL${NC}\n"
    fi
}

assert_exit() {
    local expected="$1"
    local actual="$2"
    local label="$3"
    if [[ "$actual" -ne "$expected" ]]; then
        printf "\n    ${RED}%s: expected exit %d, got %d${NC}\n" "$label" "$expected" "$actual"
        return 1
    fi
    return 0
}

assert_json_field() {
    local json="$1"
    local field="$2"
    local expected="$3"
    local label="$4"
    local actual
    actual=$(echo "$json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('$field',''))")
    if [[ "$actual" != "$expected" ]]; then
        printf "\n    ${RED}%s: expected '%s', got '%s'${NC}\n" "$label" "$expected" "$actual"
        return 1
    fi
    return 0
}

assert_json_path() {
    local json="$1"
    local path="$2"
    local expected="$3"
    local label="$4"
    local actual
    actual=$(echo "$json" | python3 -c "import json,sys; d=json.load(sys.stdin); parts='$path'.split('.'); v=d; [v:=v.get(p,None) for p in parts]; print(v if v is not None else '')")
    if [[ "$actual" != "$expected" ]]; then
        printf "\n    ${RED}%s: expected '%s', got '%s'${NC}\n" "$label" "$expected" "$actual"
        return 1
    fi
    return 0
}

assert_json_contains() {
    local json="$1"
    local path="$2"
    local expected_substring="$3"
    local label="$4"
    local actual
    actual=$(echo "$json" | python3 -c "import json,sys; d=json.load(sys.stdin); parts='$path'.split('.'); v=d; [v:=v.get(p,None) for p in parts]; print(v if v is not None else '')")
    if [[ "$actual" != *"$expected_substring"* ]]; then
        printf "\n    ${RED}%s: expected '%s' to contain '%s'${NC}\n" "$label" "$actual" "$expected_substring"
        return 1
    fi
    return 0
}

# --- Fixtures ---

filled_gate_pass() {
    local change_name="${1:-test-change}"
    local capability="${2:-test-capability}"
    python3 -c "
import json
from datetime import datetime, timezone
now = datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace('+00:00','Z')
gate = {
    'schemaVersion': '1.0',
    'status': 'pass',
    'changeName': '$change_name',
    'capability': '$capability',
    'goal': 'Validate the comprehensive test suite.',
    'createdAt': now,
    'updatedAt': now,
    'valueFrame': {
        'beneficiary': 'developers using goal-spec',
        'problemOrOpportunity': 'Comprehensive test coverage is needed.',
        'whyNow': 'Before the gate can be trusted in production.',
        'successSignal': 'All test scenarios pass with expected exit codes and JSON outputs.',
        'costRiskShape': 'Low — script-level tests with fixtures.',
        'noBuildCandidate': 'Manual spot-checking.',
        'smallerScopeCandidate': 'Test only exit codes.',
        'scopeSummary': 'A bash test runner covering comprehensive scenarios.',
        'verificationPath': 'Run scripts/test-comprehensive and observe no failures.',
    },
    'decision': {
        'rationale': 'The value gate must produce correct, consistent exit codes.',
        'noBuildConsidered': 'Considered skipping tests.',
        'smallerScopeConsidered': 'Considered testing only check.',
    },
    'constraints': ['Only Python stdlib and bash.'],
    'nonGoals': ['End-to-end OpenSpec validation (covered by other scripts).'],
    'assumptions': ['[ASSUMPTION] The workflow helper exit codes are stable.'],
    'risks': [],
    'openQuestions': [],
    'blockers': [],
    'acknowledgement': {
        'requiredFor': 'proceed_with_assumptions',
        'accepted': False,
        'acceptedAt': '',
        'acceptedBy': '',
        'rationale': '',
    },
}
print(json.dumps(gate))
"
}

# =====================================================================
# Section 1: CANONICAL ARTIFACT VALIDATORS
# =====================================================================

test_value_gate_invalid_schema_version() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "bad-schema" --capability "test" --goal "Test." > /dev/null 2>&1
    python3 -c "
import json
gate = json.load(open('$tmp/.goal-spec/value-gate.json'))
gate['schemaVersion'] = '0.9'
json.dump(gate, open('$tmp/.goal-spec/value-gate.json', 'w'))
"
    local out rc
    set +e
    out=$("$WORKFLOW" check --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 40 "$rc" "invalid schemaVersion exit" || ok=1
    echo "$out" | python3 -c "
import json,sys
d = json.load(sys.stdin)
errors = d.get('errors', [])
assert any('schemaVersion' in e for e in errors), errors
" > /dev/null 2>&1 || { printf "\n    ${RED}no schemaVersion error${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

