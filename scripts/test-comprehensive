test_acknowledgement_valid_missing_fields() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "bad-ack-fields" --capability "test" --goal "Test." > /dev/null 2>&1
    python3 -c "
import json
from datetime import datetime, timezone
now = datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace('+00:00','Z')
gate = json.load(open('$tmp/.goal-spec/value-gate.json'))
gate.update({
    'status': 'proceed_with_assumptions',
    'valueFrame': {
        'beneficiary': 'devs', 'problemOrOpportunity': 'Need test.',
        'whyNow': 'Now.', 'successSignal': 'Signal.',
        'costRiskShape': 'Low.', 'noBuildCandidate': 'None.',
        'smallerScopeCandidate': 'None.', 'scopeSummary': 'Test.',
        'verificationPath': 'Run tests.',
    },
    'decision': {
        'rationale': 'Testing needed.',
        'noBuildConsidered': 'Considered.',
        'smallerScopeConsidered': 'Considered.',
    },
    'assumptions': ['[ASSUMPTION] Something might fail.'],
    'acknowledgement': {
        'requiredFor': 'proceed_with_assumptions',
        'accepted': True, 'acceptedAt': '', 'acceptedBy': '', 'rationale': '',
    },
})
json.dump(gate, open('$tmp/.goal-spec/value-gate.json', 'w'))
"
    local out rc
    set +e
    out=$("$WORKFLOW" check --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 30 "$rc" "ack missing fields exit" || ok=1
    assert_json_field "$out" "exitCodeName" "acknowledgement_required" "exitCodeName" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_acknowledgement_valid_complete() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "good-ack" --capability "test" --goal "Test." > /dev/null 2>&1
    python3 -c "
import json
from datetime import datetime, timezone
now = datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace('+00:00','Z')
gate = json.load(open('$tmp/.goal-spec/value-gate.json'))
gate.update({
    'status': 'proceed_with_assumptions',
    'valueFrame': {
        'beneficiary': 'devs', 'problemOrOpportunity': 'Need test.',
        'whyNow': 'Now.', 'successSignal': 'Signal.',
        'costRiskShape': 'Low.', 'noBuildCandidate': 'None.',
        'smallerScopeCandidate': 'None.', 'scopeSummary': 'Test.',
        'verificationPath': 'Run tests.',
    },
    'decision': {
        'rationale': 'Testing needed.',
        'noBuildConsidered': 'Considered.',
        'smallerScopeConsidered': 'Considered.',
    },
    'assumptions': ['[ASSUMPTION] Something might fail.'],
    'acknowledgement': {
        'requiredFor': 'proceed_with_assumptions',
        'accepted': True, 'acceptedAt': now, 'acceptedBy': 'tester',
        'rationale': 'Accepting for testing purposes.',
    },
})
json.dump(gate, open('$tmp/.goal-spec/value-gate.json', 'w'))
"
    local out rc
    set +e
    out=$("$WORKFLOW" gate --pre-spec --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "complete ack gate exit" || ok=1
    assert_json_field "$out" "exitCodeName" "pass" "exitCodeName" || ok=1
    rm -rf "$tmp"
    return $ok
}

