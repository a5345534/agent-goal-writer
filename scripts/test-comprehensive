import json
report = json.load(open('$tmp/.goal-spec/reflection-report.json'))
assert report['schemaVersion'] == '1.0'
gaps = report.get('gaps', [])
assert len(gaps) > 0, f'Expected gaps, got {gaps}'
" > /dev/null 2>&1 \
        || { printf "\n    ${RED}reflection report did not detect gaps${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

