test_openspec_build_manifest_refreshes_digests() {
    local tmp
    tmp=$(mktemp -d)
    local base="$tmp/openspec/changes/refresh-test"
    mkdir -p "$base/specs/ref-cap"
    echo "# Proposal v1" > "$base/proposal.md"
    echo "# Design v1" > "$base/design.md"
    echo "# Tasks v1" > "$base/tasks.md"
    echo "# Spec v1" > "$base/specs/ref-cap/spec.md"

    python3 -c "
import json
manifest = {
    'schemaVersion': '1.0',
    'changeName': 'refresh-test',
    'generatedAt': '2024-01-01T00:00:00Z',
    'sources': [{'path': 'proposal.md', 'kind': 'proposal', 'sha256': 'deadbeef' * 8}],
}
json.dump(manifest, open('$base/source-manifest.json', 'w'))
"

    local out rc
    set +e
    out=$("$OPENSPEC" --json build-source-manifest refresh-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "build refresh exit" || ok=1

    python3 -c "
import json
manifest = json.load(open('$base/source-manifest.json'))
assert len(manifest['sources']) == 4, f'Expected 4 sources, got {len(manifest[\"sources\"])}'
" > /dev/null 2>&1 || { printf "\n    ${RED}build did not detect all 4 sources${NC}\n"; ok=1; }

    set +e
    out=$("$OPENSPEC" --json validate-source-manifest refresh-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "validate after refresh exit" || ok=1

    rm -rf "$tmp"
    return $ok
}

test_openspec_archive_preflight_basic() {
    local tmp
    tmp=$(mktemp -d)
    local base="$tmp/openspec/changes/archive-test"
    mkdir -p "$base/specs/arch-cap"

    cat > "$base/tasks.md" << 'TASKS'
# Tasks: archive-test

## 1. Implementation
- [x] 1.1 Done task
- [x] 1.2 Done task

## 2. Verification
- [x] 2.1 Verified

## Backlog
- [ ] [BACKLOG] Future work
TASKS

    echo "# Proposal" > "$base/proposal.md"
    echo "# Design" > "$base/design.md"
    echo "# Spec" > "$base/specs/arch-cap/spec.md"

    "$OPENSPEC" --json build-source-manifest archive-test --project-root "$tmp" > /dev/null 2>&1

    local out rc
    set +e
    out=$("$OPENSPEC" --json archive-preflight archive-test --project-root "$tmp" --skip-browser-layout 2>&1)
    rc=$?
    set -e
    local ok=0
    # Should fail because explainer is required by default but missing
    [[ "$rc" -ne 0 ]] || { printf "\n    ${RED}archive-preflight should fail without explainer${NC}\n"; ok=1; }

    # Verify output is valid JSON
    echo "$out" | python3 -c "
import json,sys
d = json.load(sys.stdin)
assert 'changeName' in d
assert 'checks' in d
assert 'errors' in d
assert 'status' in d
" > /dev/null 2>&1 \
        || { printf "\n    ${RED}archive-preflight output missing required fields${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

