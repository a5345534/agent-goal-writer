# =====================================================================
# Section 7: ROLE-RUN AUDIT (AUTHORING PROFILE)
# =====================================================================

test_authoring_profile_validates_against_schema() {
    local profile_path="$PROJECT_DIR/profiles/goal-spec-authoring-profile.json"
    local schema_path="$PROJECT_DIR/schemas/goal-spec-authoring-profile.schema.json"
    local ok=0
    python3 -c "
import json
profile = json.load(open('$profile_path'))
schema = json.load(open('$schema_path'))
assert profile['schemaVersion'] == '1.0'
assert profile['modelClassPolicy']['profileContainsConcreteModels'] == False
roles = profile['roles']
assert set(roles.keys()) == {'collector', 'judge', 'writer', 'explainer', 'reviewer'}
profile_text = open('$profile_path').read()
concrete_patterns = ['openai/', 'anthropic/', 'deepseek/', 'local-', 'gpt-', 'claude-']
for pattern in concrete_patterns:
    assert pattern not in profile_text.lower(), f'Concrete model pattern {pattern} found in profile'
separation_ids = {rule['id'] for rule in profile['separationRules']}
assert 'collector-judge-separation' in separation_ids
assert 'judge-writer-separation' in separation_ids
for role_name, role in roles.items():
    assert 'modelClass' in role
    assert 'purpose' in role
    assert 'responsibilities' in role
    assert 'mustNot' in role
    assert len(role['responsibilities']) > 0
    assert len(role['mustNot']) > 0
model_classes = {role['modelClass'] for role in roles.values()}
assert len(model_classes) == 5, f'Duplicate modelClass values: {model_classes}'
print('OK')
" > /dev/null 2>&1 || { printf "\n    ${RED}profile schema validation failed${NC}\n"; ok=1; }
    return $ok
}

test_authoring_profile_no_dag_runtime_leakage() {
    local ok=0
    python3 -c "
import json
from pathlib import Path
root = Path('$PROJECT_DIR')
profile = json.load(open(root / 'profiles/goal-spec-authoring-profile.json'))
# Verify the profile explicitly prohibits DAG/runtime fields in OpenSpec sources
writer_must_not = profile['roles']['writer']['mustNot']
assert any('dag' in item.lower() or 'worktree' in item.lower() for item in writer_must_not), \
    'Writer mustNot should prohibit DAG/worktree fields'
# Verify modelClassPolicy
assert profile['modelClassPolicy']['profileContainsConcreteModels'] == False
assert profile['modelClassPolicy']['concreteResolutionOwner'] == 'goal-runner harness binding catalogs'
# Check SKILL.md references downstream tools properly
skill_text = (root / 'SKILL.md').read_text()
assert 'goal-dag' in skill_text
assert 'goal-runner' in skill_text
# Verify the pipeline boundary is documented
assert 'Stage 1' in skill_text or 'stage 1' in skill_text.lower()
print('OK')
" > /dev/null 2>&1 || { printf "\n    ${RED}runtime leakage detected${NC}\n"; ok=1; }
    return $ok
}

test_authoring_profile_docs_consistency() {
    local ok=0
    python3 -c "
import json
from pathlib import Path
root = Path('$PROJECT_DIR')
profile = json.load(open(root / 'profiles/goal-spec-authoring-profile.json'))
roles = profile['roles']
doc = (root / 'docs/authoring-agent-roles.md').read_text()
for role_name, role in roles.items():
    model_class = role['modelClass']
    assert role_name in doc, f'Role {role_name} not in docs'
    assert model_class in doc, f'Model class {model_class} not in docs'
pipeline_doc = (root / 'docs/pipeline-boundaries.md').read_text()
assert 'Stage 1' in pipeline_doc or 'stage 1' in pipeline_doc.lower()
assert 'goal-spec' in pipeline_doc
print('OK')
" > /dev/null 2>&1 || { printf "\n    ${RED}doc consistency check failed${NC}\n"; ok=1; }
    return $ok
}

