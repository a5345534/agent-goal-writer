test_claim_graph_preserved_but_no_destinations() {
    local tmp
    tmp=$(mktemp -d)
    local dir="$tmp/.goal-spec/changes/preserved-no-dest"
    mkdir -p "$dir"
    "$WORKFLOW" init preserved-no-dest --project-root "$tmp" --capability "test" --goal "Test." > /dev/null 2>&1
    python3 -c "
import json
cg = json.load(open('$dir/claim-graph.json'))
cg['claims'] = [{
    'id': 'claim-001',
    'text': 'Important value claim',
    'loadBearing': True,
    'status': 'preserved',
    'destinations': []
}]
json.dump(cg, open('$dir/claim-graph.json', 'w'))
"
    filled_gate_pass "preserved-no-dest" "test" > "$dir/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" gate preserved-no-dest --pre-spec --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    # Either exit 20 (structured blocker blocks gate) or exit 40 (invalid artifact from structured check)
    if [[ "$rc" -eq 20 ]]; then
        echo "$out" | python3 -c "
import json,sys
d = json.load(sys.stdin)
blockers = d.get('blockers', [])
assert any('no OpenSpec destination' in b for b in blockers), blockers
" > /dev/null 2>&1 \
            || { printf "\n    ${RED}preserved-no-destination blocker not detected${NC}\n"; ok=1; }
    elif [[ "$rc" -eq 40 ]]; then
        :
    else
        printf "\n    ${RED}preserved no dest gate exit: expected 20 or 40, got %d${NC}\n" "$rc"
        ok=1
    fi
    rm -rf "$tmp"
    return $ok
}

