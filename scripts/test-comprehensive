# =====================================================================
# Section 9: WRITE-SPEC GATING (EXTENDED)
# =====================================================================

test_write_spec_force_overwrite() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "force-ws" --capability "force-cap" --goal "Test." > /dev/null 2>&1
    filled_gate_pass "force-ws" "force-cap" > "$tmp/.goal-spec/value-gate.json"

    local out rc
    set +e
    out=$("$WORKFLOW" write-spec --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "first write exit" || ok=1

    set +e
    out=$("$WORKFLOW" write-spec --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 50 "$rc" "second write without force exit" || ok=1

    set +e
    out=$("$WORKFLOW" write-spec --project-root "$tmp" --force 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "second write with force exit" || ok=1

    rm -rf "$tmp"
    return $ok
}

test_write_spec_preserves_value_gate_data() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "preserve-vg" --capability "preserve-cap" --goal "Preserve test." > /dev/null 2>&1
    filled_gate_pass "preserve-vg" "preserve-cap" > "$tmp/.goal-spec/value-gate.json"

    local out rc
    set +e
    out=$("$WORKFLOW" write-spec --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "write exit" || ok=1

    grep -q "preserve-vg" "$tmp/openspec/changes/preserve-vg/proposal.md" \
        || { printf "\n    ${RED}proposal missing change name${NC}\n"; ok=1; }
    grep -q "developers using goal-spec" "$tmp/openspec/changes/preserve-vg/proposal.md" \
        || { printf "\n    ${RED}proposal missing beneficiary${NC}\n"; ok=1; }

    grep -q "## Execution Handoff Notes" "$tmp/openspec/changes/preserve-vg/design.md" \
        || { printf "\n    ${RED}design missing execution handoff${NC}\n"; ok=1; }

    find "$tmp/openspec/changes/preserve-vg" -name "*.dag.json" -print -quit | grep -q . \
        && { printf "\n    ${RED}unexpected .dag.json generated${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

# =====================================================================
# Section 10: RECOVERY ACTIONS
# =====================================================================

test_recovery_action_high_stakes() {
    local tmp
    tmp=$(mktemp -d)
    local dir="$tmp/.goal-spec/changes/high-risk"
    mkdir -p "$dir"
    "$WORKFLOW" init high-risk --project-root "$tmp" --capability "test" --goal "Test." > /dev/null 2>&1
    # Fill gate with pass + loop guard blockers + high stakes risks
    python3 -c "
import json
from datetime import datetime, timezone
now = datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace('+00:00','Z')
gate = json.load(open('$dir/value-gate.json'))
gate['status'] = 'pass'
gate['changeName'] = 'high-risk'
gate['capability'] = 'test'
gate['valueFrame']['beneficiary'] = 'devs'
gate['valueFrame']['problemOrOpportunity'] = 'Need test.'
gate['valueFrame']['whyNow'] = 'Now.'
gate['valueFrame']['successSignal'] = 'Signal.'
gate['valueFrame']['costRiskShape'] = 'Low.'
gate['valueFrame']['noBuildCandidate'] = 'None.'
gate['valueFrame']['smallerScopeCandidate'] = 'None.'
gate['valueFrame']['scopeSummary'] = 'Test.'
gate['valueFrame']['verificationPath'] = 'Run tests.'
gate['decision']['rationale'] = 'Testing needed.'
gate['decision']['noBuildConsidered'] = 'Considered.'
gate['decision']['smallerScopeConsidered'] = 'Considered.'
gate['risks'] = ['Production API change', 'Security impact']
json.dump(gate, open('$dir/value-gate.json', 'w'))
state = json.load(open('$dir/workflow-state.json'))
state['loopGuards']['repeatedQuestionHashes'] = ['same','same']
json.dump(state, open('$dir/workflow-state.json', 'w'))
"
    local out rc
    set +e
    out=$("$WORKFLOW" check high-risk --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    echo "$out" | python3 -c "
import json,sys
d = json.load(sys.stdin)
action = d.get('recoveryAction', '')
assert action == 'block-high-stakes', f'Expected block-high-stakes, got {action}'
" > /dev/null 2>&1 \
        || { printf "\n    ${RED}high-stakes recovery action wrong${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

