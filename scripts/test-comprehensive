TASKS

    echo "# Proposal" > "$base/proposal.md"
    echo "# Design" > "$base/design.md"
    echo "# Spec" > "$base/specs/unc-cap/spec.md"

    "$OPENSPEC" --json build-source-manifest unchecked-test --project-root "$tmp" > /dev/null 2>&1

    local out rc
    set +e
    out=$("$OPENSPEC" --json archive-preflight unchecked-test --project-root "$tmp" --skip-browser-layout 2>&1)
    rc=$?
