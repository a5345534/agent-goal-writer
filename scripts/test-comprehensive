test_workflow_state_invalid_phase_status() {
    local tmp
    tmp=$(mktemp -d)
    local dir="$tmp/.goal-spec/changes/invalid-phase-status"
    mkdir -p "$dir"
    "$WORKFLOW" init invalid-phase-status --project-root "$tmp" --capability "test" --goal "Test." > /dev/null 2>&1
    python3 -c "
import json
state = json.load(open('$dir/workflow-state.json'))
state['phases'][0]['status'] = 'impossible_status'
json.dump(state, open('$dir/workflow-state.json', 'w'))
"
    filled_gate_pass "invalid-phase-status" "test" > "$dir/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" check invalid-phase-status --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 40 "$rc" "invalid phase status exit" || ok=1
    echo "$out" | python3 -c "
import json,sys
d = json.load(sys.stdin)
errors = d.get('errors', [])
checks = d.get('checks', [])
found = any('impossible_status' in e for e in errors)
if not found:
    found = any('impossible_status' in c.get('message','') for c in checks)
assert found, f'Expected impossible_status in errors or checks: {errors} {checks}'
" > /dev/null 2>&1 \
        || { printf "\n    ${RED}invalid phase status not detected${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

