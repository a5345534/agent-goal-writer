    assert_json_field "$out" "status" "pass" "legit values status" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_validate_name_edge_cases() {
    local tmp
    tmp=$(mktemp -d)
    local ok=0

    for name in "a" "test" "my-change" "change-123" "a-b-c"; do
        local out rc
        set +e
        out=$("$WORKFLOW" init --project-root "$tmp" --change-name "$name" --capability "test" --goal "Test." --force 2>&1)
        rc=$?
        set -e
        if [[ "$rc" -ne 0 ]]; then
            printf "\n    ${RED}valid name '%s' rejected${NC}\n" "$name"
            ok=1
            break
        fi
    done

    for name in "" "Bad Name" "UPPERCASE" "_leading-underscore" "-leading-dash" "has spaces" "has.dots"; do
        local out rc
        set +e
        out=$("$WORKFLOW" init --project-root "$tmp" --change-name "$name" --capability "test" --goal "Test." --force 2>&1)
        rc=$?
        set -e
        if [[ "$rc" -eq 0 ]] && [[ -n "$name" ]]; then
            printf "\n    ${RED}invalid name '%s' accepted${NC}\n" "$name"
            ok=1
            break
        fi
    done

    rm -rf "$tmp"
    return $ok
}

