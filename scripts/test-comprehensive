test_boundary_change_name_edge_cases() {
    local tmp
    tmp=$(mktemp -d)
    local ok=0

    local long_name
    long_name=$(python3 -c "print('a' + '-b' * 100)")
    local out rc
    set +e
    out=$("$WORKFLOW" init --project-root "$tmp" --change-name "$long_name" --capability "test" --goal "Test." --force 2>&1)
    rc=$?
    set -e
    [[ "$rc" -eq 0 ]] || { printf "\n    ${RED}long valid name rejected${NC}\n"; ok=1; }

    set +e
    out=$("$WORKFLOW" init --project-root "$tmp" --change-name "test--double" --capability "test" --goal "Test." --force 2>&1)
    rc=$?
    set -e
    [[ "$rc" -eq 0 ]] || { printf "\n    ${RED}double-hyphen name rejected${NC}\n"; ok=1; }

    set +e
    out=$("$WORKFLOW" init --project-root "$tmp" --change-name "test-" --capability "test" --goal "Test." --force 2>&1)
    rc=$?
    set -e
    [[ "$rc" -eq 0 ]] || { printf "\n    ${RED}hyphen-suffix name rejected${NC}\n"; ok=1; }

    set +e
    out=$("$WORKFLOW" init --project-root "$tmp" --change-name "123test" --capability "test" --goal "Test." --force 2>&1)
    rc=$?
    set -e
    [[ "$rc" -eq 0 ]] || { printf "\n    ${RED}digit-prefix name rejected${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

