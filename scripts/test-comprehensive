    mkdir -p "$legacy_dir"
    python3 -c "
import json
from datetime import datetime, timezone
now = datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace('+00:00','Z')
gate = {
    'schemaVersion': '1.0',
    'status': 'pass',
    'changeName': 'explicit-dir',
    'capability': 'test',
    'goal': 'Test.',
    'createdAt': now, 'updatedAt': now,
    'valueFrame': {
        'beneficiary': 'devs', 'problemOrOpportunity': 'Need test.',
        'whyNow': 'Now.', 'successSignal': 'Signal.',
        'costRiskShape': 'Low.', 'noBuildCandidate': 'None.',
        'smallerScopeCandidate': 'None.', 'scopeSummary': 'Test.',
        'verificationPath': 'Run tests.',
    },
    'decision': {
        'rationale': 'Testing needed.',
        'noBuildConsidered': 'Considered.',
        'smallerScopeConsidered': 'Considered.',
    },
    'constraints': [], 'nonGoals': [], 'assumptions': ['[ASSUMPTION] Stable.'],
    'risks': [], 'openQuestions': [], 'blockers': [],
    'acknowledgement': {
        'requiredFor': 'proceed_with_assumptions',
        'accepted': False, 'acceptedAt': '', 'acceptedBy': '', 'rationale': '',
    },
}
json.dump(gate, open('$legacy_dir/value-gate.json', 'w'))
"
    local out rc
    set +e
    out=$("$WORKFLOW" check --project-root "$tmp/wf-explicit" --artifact-dir ".writer-workflow/changes/explicit-dir" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "explicit artifact dir check exit" || ok=1
    [[ -d "$legacy_dir" ]] || { printf "\n    ${RED}legacy dir was migrated despite explicit artifact dir${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

