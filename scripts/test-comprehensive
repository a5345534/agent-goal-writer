tasks = d.get('checks', {}).get('tasks', {})
blocking = tasks.get('blocking', [])
assert len(blocking) > 0, f'Expected blocking tasks, got {blocking}'
" > /dev/null 2>&1 \
        || { printf "\n    ${RED}blocking tasks not detected${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

