# =====================================================================

test_source_manifest_unexpected_keys() {
    local tmp
    tmp=$(mktemp -d)
    local base="$tmp/openspec/changes/unexpected-keys"
    mkdir -p "$base"
    echo "# Proposal" > "$base/proposal.md"
    local hash
    hash=$(python3 -c "import hashlib; print(hashlib.sha256(open('$base/proposal.md','rb').read()).hexdigest())")
    python3 -c "
import json
manifest = {
    'schemaVersion': '1.0',
    'changeName': 'unexpected-keys',
    'generatedAt': '2024-01-01T00:00:00Z',
    'sources': [{'path': 'proposal.md', 'kind': 'proposal', 'sha256': '$hash'}],
    'unexpectedField': 'should be caught',
}
json.dump(manifest, open('$base/source-manifest.json', 'w'))
"
    local out rc
    set +e
    out=$("$OPENSPEC" --json validate-source-manifest unexpected-keys --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 1 "$rc" "unexpected keys exit" || ok=1
    rm -rf "$tmp"
    return $ok
}

