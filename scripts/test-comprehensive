test_source_manifest_schema_validation() {
    local tmp
    tmp=$(mktemp -d)
    local base="$tmp/openspec/changes/schema-test"
    mkdir -p "$base"
    echo "# Test proposal" > "$base/proposal.md"
    echo "# Test design" > "$base/design.md"
    local hash_p hash_d
    hash_p=$(python3 -c "import hashlib; print(hashlib.sha256(open('$base/proposal.md','rb').read()).hexdigest())")
    hash_d=$(python3 -c "import hashlib; print(hashlib.sha256(open('$base/design.md','rb').read()).hexdigest())")

    # Valid manifest
    python3 -c "
import json
manifest = {
    'schemaVersion': '1.0',
    'changeName': 'schema-test',
    'generatedAt': '2024-01-01T00:00:00Z',
    'sources': [
        {'path': 'proposal.md', 'kind': 'proposal', 'sha256': '$hash_p'},
        {'path': 'design.md', 'kind': 'design', 'sha256': '$hash_d'},
    ],
}
json.dump(manifest, open('$base/source-manifest.json', 'w'))
"
    local out rc ok=0
    set +e
    out=$("$OPENSPEC" --json validate-source-manifest schema-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "valid manifest exit" || ok=1

    # Invalid: empty sources
    echo '{"schemaVersion":"1.0","changeName":"schema-test","generatedAt":"2024-01-01T00:00:00Z","sources":[]}' > "$base/source-manifest.json"
    set +e
    out=$("$OPENSPEC" --json validate-source-manifest schema-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 1 "$rc" "empty sources exit" || ok=1

    # Invalid: bad sha256
    echo "{\"schemaVersion\":\"1.0\",\"changeName\":\"schema-test\",\"generatedAt\":\"2024-01-01T00:00:00Z\",\"sources\":[{\"path\":\"proposal.md\",\"kind\":\"proposal\",\"sha256\":\"not-a-valid-sha256\"}]}" > "$base/source-manifest.json"
    set +e
    out=$("$OPENSPEC" --json validate-source-manifest schema-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 1 "$rc" "bad sha256 exit" || ok=1

    # Invalid: wrong schemaVersion
    echo "{\"schemaVersion\":\"2.0\",\"changeName\":\"schema-test\",\"generatedAt\":\"2024-01-01T00:00:00Z\",\"sources\":[{\"path\":\"proposal.md\",\"kind\":\"proposal\",\"sha256\":\"$hash_p\"}]}" > "$base/source-manifest.json"
    set +e
    out=$("$OPENSPEC" --json validate-source-manifest schema-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 1 "$rc" "wrong schemaVersion exit" || ok=1

    # Invalid: path traversal
    echo "{\"schemaVersion\":\"1.0\",\"changeName\":\"schema-test\",\"generatedAt\":\"2024-01-01T00:00:00Z\",\"sources\":[{\"path\":\"../etc/passwd\",\"kind\":\"proposal\",\"sha256\":\"$hash_p\"}]}" > "$base/source-manifest.json"
    set +e
    out=$("$OPENSPEC" --json validate-source-manifest schema-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 1 "$rc" "path traversal exit" || ok=1

    # Invalid: absolute path
    echo "{\"schemaVersion\":\"1.0\",\"changeName\":\"schema-test\",\"generatedAt\":\"2024-01-01T00:00:00Z\",\"sources\":[{\"path\":\"/etc/passwd\",\"kind\":\"proposal\",\"sha256\":\"$hash_p\"}]}" > "$base/source-manifest.json"
    set +e
    out=$("$OPENSPEC" --json validate-source-manifest schema-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 1 "$rc" "absolute path exit" || ok=1

    # Invalid: bad kind
    echo "{\"schemaVersion\":\"1.0\",\"changeName\":\"schema-test\",\"generatedAt\":\"2024-01-01T00:00:00Z\",\"sources\":[{\"path\":\"proposal.md\",\"kind\":\"invalid-kind\",\"sha256\":\"$hash_p\"}]}" > "$base/source-manifest.json"
    set +e
    out=$("$OPENSPEC" --json validate-source-manifest schema-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 1 "$rc" "invalid kind exit" || ok=1

    # Invalid JSON
    echo "not json" > "$base/source-manifest.json"
    set +e
    out=$("$OPENSPEC" --json validate-source-manifest schema-test --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 1 "$rc" "invalid JSON exit" || ok=1

    rm -rf "$tmp"
    return $ok
}

