    echo "$out" | python3 -c "
import json,sys
d = json.load(sys.stdin)
warnings = d.get('warnings', [])
assert any('blocked' in w.lower() and ('blocker' in w.lower() or 'question' in w.lower()) for w in warnings), warnings
" > /dev/null 2>&1 || { printf "\n    ${RED}missing blocked-without-blocker warning${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

